{
    "_comment": "IoT Connector status/error codes. Used by generate_openapi.py to inject per-command error tables.",
    "codes": [
        {
            "code": 0,
            "description": "Success",
            "iot_status_code": "IOT_STATUS_SUCCESS",
            "commands": ["*"]
        },
        {
            "code": 1,
            "description": "Command payload is accepted",
